[Unit]
Description=HAX BOT 7.8 Telegram Service
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/hax-bot
EnvironmentFile=-/opt/hax-bot/config.env
Environment="PYTHONPATH=/opt/hax-bot"
Environment="PATH=/opt/hax-bot/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/opt/hax-bot/venv/bin/python -m app.bot.main
Restart=always
RestartSec=10
StandardOutput=append:/opt/hax-bot/logs/bot.log
StandardError=append:/opt/hax-bot/logs/bot_error.log

[Install]
WantedBy=multi-user.target
